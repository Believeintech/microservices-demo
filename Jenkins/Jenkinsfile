pipeline {
    agent {
        label 'docker'
    }

    environment {
        DOCKERHUB_REPO = "rajesh984"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Believeintech/microservices-demo.git'
            }
        }

        stage('SonarQube Analysis') {
               steps {
                 script {       
                     def scannerHome = tool 'sonar-scanner'

                     withSonarQubeEnv('SonarQube') {

                     sh """
                       ${scannerHome}/bin/sonar-scanner \
                       -Dsonar.projectKey=online-boutique \
                       -Dsonar.projectName=online-boutique \
                       -Dsonar.sources=src \
                       -Dsonar.exclusions=**/*.java
                    """
            }
        }
    
    }
}

        stage('Build Images') {
            steps {
                sh '''
                docker build -t $DOCKERHUB_REPO/onlineboutique-frontend:${BUILD_NUMBER} src/frontend

                docker build -t $DOCKERHUB_REPO/onlineboutique-cartservice:${BUILD_NUMBER} src/cartservice/src

                docker build -t $DOCKERHUB_REPO/onlineboutique-productcatalogservice:${BUILD_NUMBER} src/productcatalogservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-currencyservice:${BUILD_NUMBER} src/currencyservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-checkoutservice:${BUILD_NUMBER} src/checkoutservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-emailservice:${BUILD_NUMBER} src/emailservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-paymentservice:${BUILD_NUMBER} src/paymentservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-recommendationservice:${BUILD_NUMBER} src/recommendationservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-shippingservice:${BUILD_NUMBER} src/shippingservice

                docker build -t $DOCKERHUB_REPO/onlineboutique-adservice:${BUILD_NUMBER} src/adservice

                '''
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                docker push $DOCKERHUB_REPO/onlineboutique-frontend:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-cartservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-productcatalogservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-currencyservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-checkoutservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-emailservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-paymentservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-recommendationservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-shippingservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-adservice:${BUILD_NUMBER}

                '''
            }
        }
        
         stage('Deploy') {
             steps {
              sshagent(['minikube-ssh']) {
                sh """
                 ssh -o StrictHostKeyChecking=no ubuntu@172.31.36.144 '
            
                 kubectl set image deployment/frontend \
                 server=rajesh984/onlineboutique-frontend:${BUILD_NUMBER}

                 kubectl set image deployment/cartservice \
                 server=rajesh984/onlineboutique-cartservice:${BUILD_NUMBER}

                 kubectl set image deployment/productcatalogservice \
                 server=rajesh984/onlineboutique-productcatalogservice:${BUILD_NUMBER}

                 kubectl set image deployment/currencyservice \
                 server=rajesh984/onlineboutique-currencyservice:${BUILD_NUMBER}
 
                 kubectl set image deployment/checkoutservice \
                    server=rajesh984/onlineboutique-checkoutservice:${BUILD_NUMBER}

                kubectl set image deployment/emailservice \
                    server=rajesh984/onlineboutique-emailservice:${BUILD_NUMBER}

                kubectl set image deployment/paymentservice \
                    server=rajesh984/onlineboutique-paymentservice:${BUILD_NUMBER}

                kubectl set image deployment/recommendationservice \
                    server=rajesh984/onlineboutique-recommendationservice:${BUILD_NUMBER}

                kubectl set image deployment/shippingservice \
                    server=rajesh984/onlineboutique-shippingservice:${BUILD_NUMBER}

                kubectl set image deployment/adservice \
                    server=rajesh984/onlineboutique-adservice:${BUILD_NUMBER}



                 kubectl rollout status deployment/frontend
                 kubectl rollout status deployment/cartservice
                 kubectl rollout status deployment/productcatalogservice
                 kubectl rollout status deployment/currencyservice
                 kubectl rollout status deployment/checkoutservice
                 kubectl rollout status deployment/emailservice
                 kubectl rollout status deployment/paymentservice
                 kubectl rollout status deployment/recommendationservice
                 kubectl rollout status deployment/shippingservice
                 kubectl rollout status deployment/adservice

                 '
            
                """
         }
     }
  }
}
}
