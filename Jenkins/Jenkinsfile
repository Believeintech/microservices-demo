pipeline {
    agent {
        label 'docker'
    }

    stages {

        stage('Agent Verification') {
            steps {
                sh 'hostname'
                sh 'pwd'
                sh 'whoami'
            }
        }

        stage('Tool Verification') {
            steps {
                sh 'java -version'
                sh 'git --version'
                sh 'docker --version'
            }
        }

        stage('Docker Build') {
            steps {
                 dir('src/frontend') {
                sh 'docker build -t onlineboutique-frontend:v1 .'
        }
    }
}