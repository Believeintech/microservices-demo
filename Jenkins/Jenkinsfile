pipeline {
    agent {
        label 'docker'
    }

    environment {
        DOCKERHUB_REPO = "rajesh984"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Believeintech/microservices-demo.git'
            }
        }

        stage('Build Images') {
            steps {
                sh '''
                docker build -t $DOCKERHUB_REPO/onlineboutique-frontend:${BUILD_NUMBER} src/frontend

                docker build -t $DOCKERHUB_REPO/onlineboutique-cartservice:${BUILD_NUMBER} src/cartservice/src

                docker build -t $DOCKERHUB_REPO/onlineboutique-productcatalogservice:${BUILD_NUMBER} src/productcatalogservice
                '''
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    '''
                }
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                docker push $DOCKERHUB_REPO/onlineboutique-frontend:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-cartservice:${BUILD_NUMBER}

                docker push $DOCKERHUB_REPO/onlineboutique-productcatalogservice:${BUILD_NUMBER}
                '''
            }
        }
    }
        
    stage('Deploy') {
    steps {
        sshagent(['minikube-ssh']) {
            sh """
            ssh -o StrictHostKeyChecking=no ubuntu@172.31.36.144 '
            
            kubectl set image deployment/frontend \
            server=rajesh984/onlineboutique-frontend:${BUILD_NUMBER}

            kubectl rollout status deployment/frontend

            '
            """
        }
    }
}
}
         